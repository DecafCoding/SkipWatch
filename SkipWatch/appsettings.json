{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "YouTube": {
    "ApiKey": "",
    "DailyQuotaLimit": 10000,
    "CeilingUnits": 9000
  },
  "Apify": {
    "Token": "",
    "RunTimeoutSeconds": 300,
    "PreferredLanguage": "en",
    "PreferAutoGenerated": true
  },
  "Discovery": {
    "Cron": "*/30 * * * *",
    "ChannelsPerRound": 5,
    "InitialVideoCap": 20,
    "RollingVideoCap": 10,
    "MinVideoDurationSeconds": 180,
    "MaxVideoDurationMinutes": 60,
    "MaxRetryAttempts": 3
  }
}
