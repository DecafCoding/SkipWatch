@inject ITopicService TopicService

@if (IsLoading)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading topics...</span>
        </div>
    </div>
}
else if (Topics.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="bi bi-search text-muted" style="font-size: 2.5rem;"></i>
            <h6 class="mt-3 text-muted mb-1">No topics yet</h6>
            <p class="text-muted small mb-0">Add one above to start polling YouTube for keyword matches.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var topic in Topics)
        {
            <div class="col-lg-4 col-md-6">
                <TopicCard Topic="@topic"
                           OnTopicDeleted="HandleTopicDeleted"
                           OnTopicEnabledChanged="HandleTopicEnabledChanged" />
            </div>
        }
    </div>
}

@code {
    [Parameter] public EventCallback<int> OnTopicsChanged { get; set; }

    private List<TopicDto> Topics { get; set; } = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    public async Task RefreshAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        try
        {
            Topics = await TopicService.GetAllAsync();
            await OnTopicsChanged.InvokeAsync(Topics.Count);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleTopicDeleted(int topicId)
    {
        Topics = Topics.Where(t => t.Id != topicId).ToList();
        await OnTopicsChanged.InvokeAsync(Topics.Count);
        StateHasChanged();
    }

    private void HandleTopicEnabledChanged((int Id, bool Enabled) change)
    {
        var index = Topics.FindIndex(t => t.Id == change.Id);
        if (index >= 0)
        {
            Topics[index] = Topics[index] with { Enabled = change.Enabled };
            StateHasChanged();
        }
    }
}
